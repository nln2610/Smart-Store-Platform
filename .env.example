# ===== DATABASE (Supabase) =====
# Lấy tại: Supabase Dashboard → Project Settings → Database → Connection string → JDBC
SUPABASE_DB_URL=jdbc:postgresql://db.xxxx.supabase.co:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_supabase_password

# ===== JWT =====
# Chuỗi bất kỳ, tối thiểu 32 ký tự, dùng để ký JWT token
# Gợi ý tạo ngẫu nhiên: https://generate-secret.vercel.app/64
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# ===== GEMINI AI =====
# Lấy tại: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your_gemini_api_key